    {
      "title": "Instance Traffic (who's serving requests?)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s])) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 50,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
        {
      "title": "Latency (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Saturation: CPU & Memory",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "avg(system_cpu_percent)",
          "legendFormat": "CPU %"
        },
        {
          "expr": "avg(system_memory_percent)",
          "legendFormat": "Memory %"
        },
        {
          "expr": "85",
          "legendFormat": "Alert Threshold (85%)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Alert Threshold (85%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "(sum(rate(http_errors_total[30s])) / sum(rate(http_requests_total[30s])) * 100) or vector(0)",
          "legendFormat": "Error %"
        },
        {
          "expr": "5",
          "legendFormat": "Alert Threshold (5%)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Alert Threshold (5%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
