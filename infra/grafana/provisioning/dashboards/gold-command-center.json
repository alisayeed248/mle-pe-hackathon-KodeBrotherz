  "annotations": {
    "list": []
  },
  "title": "Gold - Command Center (4 Golden Signals)",
  "uid": "gold-command-center",
  "version": 3,
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1s",
  "liveNow": true,
  "time": {
    "from": "now-5m",
    "to": "now"
