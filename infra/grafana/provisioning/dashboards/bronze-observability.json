{
  "annotations": {
    "list": []
  },
  "title": "Bronze Tier - Observability Evidence",
  "uid": "bronze-observability",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "title": "",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "# /metrics Endpoint Evidence\n**Real-time metrics** from Prometheus-compatible `/metrics` endpoint • Scraped every 5s • 3 Flask replicas"
      }
    },
    {
      "title": "",
      "type": "text",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "### Logs Without SSH\n```\ndocker-compose logs app1 app2 app3\n```"
      }
    },
    {
      "title": "CPU %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "avg(system_cpu_percent)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "RAM %",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "avg(system_memory_percent)",
          "legendFormat": "RAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Requests/sec",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "max": 200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Active",
      "type": "stat",
      "gridPos": { "x": 12, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "sum(http_requests_active)",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      }
    },
    {
      "title": "Errors",
      "type": "stat",
      "gridPos": { "x": 16, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total[1m])) or vector(0)",
          "legendFormat": "Errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      }
    },
    {
      "title": "p95 Latency",
      "type": "stat",
      "gridPos": { "x": 20, "y": 3, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      }
    },
    {
      "title": "CPU & Memory Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg(system_cpu_percent)",
          "legendFormat": "System CPU %"
        },
        {
          "expr": "avg(system_memory_percent)",
          "legendFormat": "System RAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Request Rate & Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s]))",
          "legendFormat": "Requests/sec"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[30s])) by (le)) * 100",
          "legendFormat": "p95 Latency (×100ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Database Operations",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(db_queries_total[30s])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 30
          }
        }
      }
    },
    {
      "title": "Request Distribution by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 30
          }
        }
      }
    }
  ]
}
